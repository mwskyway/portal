      {q:'Какой документ является основным разрешительным для работы бортпроводником?',opts:['Паспорт','Свидетельство бортпроводника','Медицинская справка','Трудовая книжка'],correct:1,exp:'Свидетельство бортпроводника (Cabin Crew Attestation) — обязательный документ ИКАО.'},
      {q:'Главная обязанность бортпроводника на борту?',opts:['Сервис питания','Безопасность пассажиров','Навигация','Коммуникация с землёй'],correct:1,exp:'Несмотря на сервисные функции, безопасность пассажиров — приоритет номер один.'},
    ]
  },
  quiz2: {
    title:'Безопасность на борту',
    questions:[
      {q:'Сколько секунд даётся на эвакуацию самолёта по стандарту FAA?',opts:['60','90','120','180'],correct:1,exp:'Стандарт FAA требует полной эвакуации за 90 секунд.'},
      {q:'Какой огнетушитель используется при пожаре в туалете?',opts:['Углекислотный','Порошковый','Хладоновый','Пенный'],correct:2,exp:'В туалетах самолётов используются хладоновые (Halon) огнетушители.'},
      {q:'На какой высоте автоматически выпадают кислородные маски?',opts:['10,000 футов','12,000 футов','14,000 футов','15,000 футов'],correct:3,exp:'Маски выпадают при снижении давления до уровня 14 000 футов.'},
      {q:'Что означает сигнал "MAYDAY"?',opts:['Срочный сигнал','Сигнал бедствия','Техническая неисправность','Медицинская ситуация'],correct:1,exp:'MAYDAY — международный сигнал бедствия, повторяемый трижды.'},
      {q:'Что следует делать ПЕРВЫМ при обнаружении подозрительного предмета?',opts:['Убрать предмет','Сообщить командиру','Эвакуировать всех','Проверить предмет'],correct:1,exp:'Немедленно сообщить командиру воздушного судна — первое обязательное действие.'},
    ]
  },
  quiz3:{title:'Сервис и обслуживание',questions:[
    {q:'Как называется стандарт сервиса Emirates в бизнес-классе?',opts:['Gold Service','Platinum Care','Skywards Premium','Emirates Service Standard'],correct:0,exp:'Emirates использует название Gold Service для премиального обслуживания.'},
    {q:'При столкновении с агрессивным пассажиром первый шаг?',opts:['Вызвать полицию','Де-эскалация','Изолировать пассажира','Предложить алкоголь'],correct:1,exp:'Де-эскалация — снижение напряжённости через спокойный диалог — всегда первый шаг.'},
    {q:'Что входит в "UMNR" обслуживание?',opts:['Бизнес-класс','Дети без сопровождения','VIP-пассажиры','Пассажиры с инвалидностью'],correct:1,exp:'UMNR (Unaccompanied Minor) — дети, путешествующие без сопровождения взрослых.'},
    {q:'При подаче горячего напитка пассажиру рекомендуется?',opts:['Наклонить стакан','Поставить салфетку','Предупредить словами','Всё вышеперечисленное'],correct:3,exp:'Все три действия входят в стандарт безопасной подачи горячих напитков.'},
    {q:'Срок годности пищи в бортовом питании определяется?',opts:['Датой погрузки','HACCP стандартами','Только запахом','Сроком полёта'],correct:1,exp:'Система HACCP — международный стандарт контроля безопасности питания на борту.'},
  ]},
  quiz4:{title:'Авиационная медицина',questions:[
    {q:'Нормальный уровень кислорода в кабине по ИКАО?',opts:['19%','20%','21%','22%'],correct:1,exp:'Стандарт ИКАО — поддержание уровня кислорода 20% в герметичной кабине.'},
    {q:'Признак гипоксии первой степени?',opts:['Потеря сознания','Эйфория и головная боль','Синюшность кожи','Остановка дыхания'],correct:1,exp:'На начальном этапе гипоксия проявляется эйфорией, снижением концентрации и головной болью.'},
    {q:'AED — это?',opts:['Аварийный выход','Автоматический дефибриллятор','Система кондиционирования','Датчик давления'],correct:1,exp:'AED — Automated External Defibrillator (автоматический внешний дефибриллятор).'},
    {q:'При инфаркте на борту первое действие?',opts:['Нитроглицерин','Аспирин','Вызвать врача среди пассажиров','Объявить по громкой связи'],correct:2,exp:'Сначала объявляется о наличии врача на борту через пассажирскую связь.'},
    {q:'Минимальное число CPR-компрессий в минуту?',opts:['60','80','100','120'],correct:2,exp:'Современный стандарт CPR требует 100–120 компрессий грудной клетки в минуту.'},
  ]},
  quiz5:{title:'Авиационный английский',questions:[
    {q:'"Cross-check and all call" означает?',opts:['Проверить список','Проверить двери и доложить командиру','Начало посадки','Окончание рейса'],correct:1,exp:'Cross-check — проверить дверь, all call — доложить командиру о готовности всех дверей.'},
    {q:'Стандартное приветствие пассажира бизнес-класса?',opts:['"Hi there"','"Good day, welcome aboard"','"Hello friend"','"Hey, welcome"'],correct:1,exp:'Формальное приветствие "Good day/evening, welcome aboard" — профессиональный стандарт.'},
    {q:'"NITS" briefing включает?',opts:['Nature, Intent, Time, Special instructions','Name, ID, Time, Seat','Navigation, Instruction, Time, Safety','None of the above'],correct:0,exp:'NITS: Nature — суть ситуации, Intent — намерения командира, Time — время, Special — указания.'},
    {q:'Как правильно объявить о задержке рейса на английском?',opts:['"Flight is late"','"We are experiencing a delay"','"Wait please"','"Not on time"'],correct:1,exp:'"We are experiencing a delay" — формулировка, принятая в авиационной коммуникации.'},
    {q:'"Able-bodied passenger" (ABP) — это?',opts:['Бизнес-пассажир','Пассажир, способный помочь при эвакуации','VIP пассажир','Частый гость'],correct:1,exp:'ABP — физически здоровый пассажир, способный помочь экипажу при аварийной ситуации.'},
  ]},
  quiz6:{title:'Внешний вид и этикет',questions:[
    {q:'Максимальная длина ногтей по стандарту большинства авиакомпаний?',opts:['2 мм','3 мм','5 мм','Не ограничена'],correct:2,exp:'Стандарт — не более 5 мм, чтобы не мешать работе с оборудованием.'},
    {q:'Какой цвет помады считается стандартным у большинства авиакомпаний?',opts:['Нейтральный/нюд','Красный','Яркий розовый','Без ограничений'],correct:0,exp:'Нейтральные тона — предпочтение большинства авиакомпаний для профессионального образа.'},
    {q:'Как носят форменный шейный платок?',opts:['Свободно','Строго по инструкции авиакомпании','Любым способом','Не носят'],correct:1,exp:'Каждая авиакомпания имеет строгую инструкцию по ношению всех элементов формы.'},
    {q:'Видимые татуировки на шее/руках при работе в авиакомпании?',opts:['Разрешены','Запрещены у большинства','Не важно','Зависит от рейса'],correct:1,exp:'Большинство ведущих авиакомпаний запрещают видимые татуировки в форме.'},
    {q:'Профессиональная улыбка бортпроводника — это?',opts:['Всегда одинакова','Искренняя и уместная','Только для бизнес-класса','Обязательна каждую секунду'],correct:1,exp:'Улыбка должна быть искренней и уместной контексту — не механической.'},
  ]},
  quiz_final:{title:'Финальный экзамен',questions:[
    {q:'Главный приоритет бортпроводника на борту?',opts:['Питание','Безопасность','Имидж','Языки'],correct:1,exp:'Безопасность пассажиров — абсолютный приоритет, закреплённый ИКАО.'},
    {q:'Время эвакуации самолёта по стандарту FAA?',opts:['60 сек','90 сек','120 сек','180 сек'],correct:1,exp:'90 секунд — стандарт FAA для полной эвакуации.'},
    {q:'AED расшифровывается как?',opts:['Авиационный эвакуационный документ','Автоматический внешний дефибриллятор','Аварийный экстренный доступ','Авиационный экипажный документ'],correct:1,exp:'AED — Automated External Defibrillator.'},
    {q:'"Cross-check and all call" — команда для?',opts:['Посадки','Проверки дверей','Питания','Взлёта'],correct:1,exp:'Проверка всех аварийных дверей экипажем.'},
    {q:'NITS briefing — первая буква означает?',opts:['Name','Navigation','Nature','Normal'],correct:2,exp:'Nature — суть ситуации, первый элемент брифинга.'},
    {q:'При гипоксии первый симптом?',opts:['Синюшность','Эйфория','Боль','Судороги'],correct:1,exp:'Лёгкая эйфория и снижение концентрации — первые признаки гипоксии.'},
    {q:'Де-эскалация — это?',opts:['Увеличение напряжённости','Снижение конфликта','Изоляция пассажира','Вызов полиции'],correct:1,exp:'Де-эскалация — метод снижения конфликтного напряжения через диалог.'},
    {q:'UMNR означает?',opts:['Обычный пассажир','Дети без сопровождения','VIP-пассажир','Инвалид'],correct:1,exp:'Unaccompanied Minor — ребёнок без сопровождения.'},
    {q:'Уровень кислорода в кабине по ИКАО?',opts:['19%','20%','21%','22%'],correct:1,exp:'20% — стандарт ИКАО.'},
    {q:'Профессиональное приветствие пассажира?',opts:['"Hi"','"Good day, welcome aboard"','"Hey"','"Hello friend"'],correct:1,exp:'Формальное приветствие — стандарт профессиональной коммуникации.'},
  ]}
};

// Lesson content snippets
const CONTENT = {
  intro:`<h3>История авиации и становление профессии</h3><p>Профессия бортпроводника зародилась в 1930-х годах. Первые «стюардессы» были медсёстрами — их задачей было успокаивать пассажиров, боящихся полётов. Постепенно роль трансформировалась от медицинского ассистента к универсальному специалисту по безопасности и сервису.</p><div class="highlight">«Бортпроводник — это прежде всего специалист по безопасности, который умеет делать это с улыбкой» — Emirates Training Academy</div><h3>Первые шаги в авиации</h3><p>В 1930 году Эллен Чёрч стала первой стюардессой на борту United Airlines. Её инициатива доказала, что присутствие обученного персонала на борту значительно повышает доверие пассажиров к авиатранспорту.</p><ul><li>1930 — первая стюардесса (США)</li><li>1944 — Чикагская конвенция ИКАО устанавливает стандарты</li><li>1970-е — массовая профессионализация экипажей</li><li>2000-е — введение международной сертификации</li></ul>`,
  duties:`<h3>Ваши обязанности на борту</h3><p>Работа бортпроводника включает два ключевых блока: безопасность и сервис. Безопасность всегда в приоритете — это закреплено международными стандартами ИКАО и FAA.</p><h3>Основные функции</h3><ul><li><strong>Предполётная подготовка</strong> — проверка оборудования, инструктаж пассажиров, подготовка кабины</li><li><strong>Во время полёта</strong> — наблюдение за салоном, обслуживание, работа с особыми ситуациями</li><li><strong>Аварийные ситуации</strong> — немедленное применение обученных процедур</li><li><strong>Послеполётные процедуры</strong> — проверка кабины, отчётность</li></ul><div class="highlight">Помните: пассажиры смотрят на вас как на ориентир спокойствия. Ваше поведение задаёт тон всему рейсу.</div>`,
  requirements:`<h3>Требования ведущих авиакомпаний</h3><p>Emirates, Etihad, Qatar Airways и другие ведущие авиакомпании устанавливают чёткие критерии отбора кандидатов. Понимание этих требований — первый шаг к мечте.</p><ul><li>Возраст: как правило, от 18 до 30 лет (зависит от авиакомпании)</li><li>Рост: 158–185 см (досягаемость 212 см)</li><li>Английский язык: не ниже Upper-Intermediate</li><li>Образование: не ниже среднего специального</li><li>Отсутствие видимых татуировок и пирсинга в форме</li></ul>`,
  medical:`<h3>Медицинские и физические стандарты</h3><p>Авиационные регуляторы устанавливают обязательные медицинские требования для членов экипажа. Ежегодное медицинское освидетельствование — неотъемлемая часть профессии.</p><ul><li>Зрение: скорректированное до нормы (линзы, очки — допустимо)</li><li>Слух: без значительных нарушений</li><li>Сердечно-сосудистая система: без хронических патологий</li><li>Психологическое здоровье: тесты на стрессоустойчивость</li></ul>`,
  emergency:`<h3>Аварийное оборудование воздушного судна</h3><p>Знание расположения и применения аварийного оборудования — основа безопасности на борту. Каждый бортпроводник обязан знать оборудование своей позиции наизусть.</p><ul><li><strong>Аварийные выходы</strong> — типы, маркировка, процедура открытия</li><li><strong>Кислородные системы</strong> — ручные баллоны, химические генераторы</li><li><strong>Спасательные жилеты</strong> — расположение, надевание, активация</li><li><strong>Огнетушители</strong> — типы и зоны применения</li><li><strong>ELT</strong> — аварийный маяк</li></ul>`,
  evacuation:`<h3>Процедуры аварийной эвакуации</h3><p>Стандарт FAA требует эвакуации всех пассажиров менее чем за 90 секунд. Это достигается чёткой координацией экипажа и правильными командами.</p><div class="highlight">Команда «JUMP AND SLIDE» подаётся только командиром или старшим бортпроводником после оценки состояния выхода.</div><h3>Ключевые команды</h3><ul><li>«BRACE! BRACE! BRACE!» — принять позу защиты</li><li>«RELEASE SEATBELTS, LEAVE EVERYTHING, COME THIS WAY» — эвакуация</li><li>«JUMP AND SLIDE» — прыгать и скользить по трапу</li><li>«KEEP MOVING» — не останавливаться на трапе</li></ul>`,
  fire:`<h3>Пожарная безопасность на борту</h3><p>Пожар — один из наиболее опасных инцидентов. Экипаж обязан действовать по принципу CAT: Confirm (подтвердить), Attack (тушить), Tell (сообщить).</p>`,
  firstaid:`<h3>Первая медицинская помощь на высоте</h3><p>На борту нет врачей — только вы и ваши знания. Каждый бортпроводник проходит обязательный курс первой помощи и тренинг по использованию AED.</p>`,
  hw_safety:`<h3>Домашнее задание: Аварийный сценарий</h3><p>Опишите ваши действия при следующем сценарии: в 40 минутах от посадки пассажир в ряду 14B теряет сознание. Рядом — его супруга в панике. Остальные пассажиры наблюдают.</p><p>Опишите пошагово все ваши действия, команды, коммуникацию с командиром и взаимодействие с другим экипажем. Оформите в виде документа и загрузите ниже.</p>`,
  service_std:`<h3>Стандарты бортового сервиса</h3><p>Каждая авиакомпания имеет детализированный мануал сервиса (SOM — Service Operations Manual). Базовые принципы едины для всей индустрии.</p><ul><li>Приветствие при посадке — стоя, улыбка, зрительный контакт</li><li>Помощь с ручной кладью — по запросу и по ситуации</li><li>Предложение газет, напитков перед взлётом</li><li>Соблюдение последовательности обслуживания рядов</li></ul>`,
  bizclass:`<h3>Обслуживание в бизнес-классе</h3><p>Бизнес-класс требует индивидуального подхода к каждому пассажиру. Запомните имена пассажиров, их предпочтения. Обращайтесь по имени.</p>`,
  special_pax:`<h3>Работа с особыми категориями пассажиров</h3><ul><li><strong>UMNR</strong> — дети без сопровождения</li><li><strong>WCHR/WCHS/WCHC</strong> — пассажиры с ограниченными возможностями</li><li><strong>DEPA/DEPU</strong> — депортируемые лица</li><li><strong>MEDA</strong> — медицинские случаи</li><li><strong>VIP/CIP</strong> — высокопоставленные пассажиры</li></ul>`,
  conflicts:`<h3>Управление конфликтными ситуациями</h3><p>Авиационная психология выделяет несколько типов сложных пассажиров: тревожный, агрессивный, нетрезвый, паникующий. Для каждого — своя техника.</p><div class="highlight">Принцип LEAP: Listen (выслушай), Empathize (посочувствуй), Apologize (принеси извинения), Problem-solve (решай проблему).</div>`,
  physiology:`<h3>Физиология полёта</h3><p>Человеческий организм испытывает ряд стрессов во время полёта: сниженное давление, пониженная влажность воздуха, космическое излучение, шум, вибрация и сдвиг часовых поясов.</p>`,
  hypoxia:`<h3>Гипоксия и декомпрессия</h3><p>Гипоксия — недостаток кислорода в крови. На крейсерской высоте 30–40 000 футов без герметичной кабины выживание человека невозможно.</p><ul><li>Первые признаки: эйфория, головная боль, снижение концентрации</li><li>Время сознания без кислорода на 35 000 футов: ~15–30 секунд</li><li>Декомпрессия кабины: немедленное снижение до 10 000 футов</li></ul>`,
  medical_ev:`<h3>Медицинские ситуации на борту</h3><p>Наиболее частые медицинские ситуации: обмороки, гипогликемия, приступы паники, аллергические реакции, сердечные приступы, роды (редко).</p>`,
  med_equip:`<h3>Использование медицинского оборудования</h3><p>На борту имеется: аптечка первой помощи, расширенный медицинский набор (EMK), AED, кислородный баллон, носилки (на широкофюзеляжных самолётах).</p>`,
  aveng:`<h3>Авиационный английский</h3><p>Aviation English — специализированный язык международного общения в авиации. ИКАО установила требование Level 4 (Operational) для всех членов экипажа международных рейсов.</p>`,
  announcements:`<h3>Стандартные объявления на борту</h3><p>Каждое объявление имеет установленную структуру: приветствие, информация, действие. Объявления делаются на языке вылета и на английском.</p><div class="highlight">«Ladies and gentlemen, on behalf of your Captain and the entire crew, welcome aboard MW Skyway flight...»</div>`,
  foreign_pax:`<h3>Работа с иностранными пассажирами</h3><p>Культурная компетентность — ключевой навык. Изучите основные культурные особенности пассажиров из разных стран: жесты, предпочтения, табу.</p>`,
  hw_lang:`<h3>Практика: Ролевые игры</h3><p>Запишите аудио или видео (2–3 минуты): разыграйте сцену работы с иностранным пассажиром. Покажите стандартное приветствие, помощь с местом, подачу напитка и объявление о посадке — всё на английском.</p>`,
  dresscode:`<h3>Дресс-код и форма</h3><p>Форма бортпроводника — лицо авиакомпании. Каждый элемент: от цвета помады до способа завязывания галстука — прописан в Grooming Manual.</p>`,
  appearance:`<h3>Стандарты внешнего вида</h3><ul><li>Волосы: аккуратно уложены, убраны от лица</li><li>Макияж: натуральный и профессиональный</li><li>Ногти: чистые, аккуратные, не длиннее 5 мм</li><li>Парфюм: лёгкий, не раздражающий</li><li>Форма: идеально выглажена, без пятен</li></ul>`,
  profbehav:`<h3>Профессиональное поведение</h3><p>Бортпроводник — представитель авиакомпании 24/7. В форме особенно важно следить за поведением в общественных местах.</p>`,
  hw_image:`<h3>Практика: Самопрезентация</h3><p>Сделайте фотосет в форме или деловой одежде: фото в полный рост и портрет. Приложите краткое описание: как вы готовились к фотографированию, какие стандарты соблюдали.</p>`,
  review_safety:`<h3>Повторение: Безопасность</h3><p>Ключевые темы для финального экзамена: аварийное оборудование, процедуры эвакуации, пожарная безопасность, первая помощь, медицинские ситуации на борту.</p>`,
  review_service:`<h3>Повторение: Сервис и медицина</h3><p>Финальное повторение тем сервиса, коммуникации, медицинских стандартов и профессионального имиджа перед итоговым экзаменом.</p>`,
  certificate:`<h3>Поздравляем с завершением курса!</h3><p>Вы успешно прошли программу MW SKYWAY Cabin Crew Training. Ваш сертификат готовится к выдаче.</p><div class="highlight">Сертификат MW SKYWAY подтверждает прохождение полного курса подготовки бортпроводников и будет направлен на вашу электронную почту в течение 3 рабочих дней.</div><p>Желаем вам успешного прохождения отборов в ведущих авиакомпаниях мира. ✈️</p>`,
};

// ══════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════
let state = {
  user: null,
  completedLessons: new Set(),
  quizScores: {},
  currentLesson: null,
  currentQuiz: {q:0, answers:[], answered:false},
  uploads: {}
};

function loadState(){
  const saved = localStorage.getItem('mw_lms_state');
  if(saved){
    const s = JSON.parse(saved);
    state.user = s.user;
    state.completedLessons = new Set(s.completedLessons||[]);
    state.quizScores = s.quizScores||{};
    state.uploads = s.uploads||{};
  }
}
function saveState(){
  localStorage.setItem('mw_lms_state', JSON.stringify({
    user: state.user,
    completedLessons: [...state.completedLessons],
    quizScores: state.quizScores,
    uploads: state.uploads
  }));
}

// ══════════════════════════════════════════
//  AUTH
// ══════════════════════════════════════════
function switchTab(t){
  document.querySelectorAll('.auth-tab').forEach((el,i)=>el.classList.toggle('on', (i===0&&t==='login')||(i===1&&t==='register')));
  document.getElementById('loginForm').style.display = t==='login'?'block':'none';
  document.getElementById('registerForm').style.display = t==='register'?'block':'none';
}

function doLogin(){
  const email = document.getElementById('loginEmail').value.trim();
  const pass = document.getElementById('loginPass').value;
  if(!email||!pass){showLoginErr('Заполните все поля');return;}
  const users = JSON.parse(localStorage.getItem('mw_users')||'[]');
  const user = users.find(u=>u.email===email&&u.pass===pass);
  if(!user){showLoginErr('Неверный email или пароль');return;}
  state.user = user;
  loadUserState(user.email);
  enterApp();
}

function doRegister(){
  const name = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pass = document.getElementById('regPass').value;
  const code = document.getElementById('regCode').value.trim();
  const ACCESS_CODES = ['SKYWAY2025','MW2025','CABIN2025'];
  if(!name||!email||!pass){showRegErr('Заполните все поля');return;}
  if(pass.length<6){showRegErr('Пароль минимум 6 символов');return;}
  if(!ACCESS_CODES.includes(code.toUpperCase())){showRegErr('Неверный код доступа');return;}
  const users = JSON.parse(localStorage.getItem('mw_users')||'[]');
  if(users.find(u=>u.email===email)){showRegErr('Email уже зарегистрирован');return;}
  const user = {name,email,pass,joined:new Date().toLocaleDateString('ru-RU')};
  users.push(user);
  localStorage.setItem('mw_users',JSON.stringify(users));
  state.user = user;
  state.completedLessons = new Set();
  state.quizScores = {};
  state.uploads = {};
  saveState();
  enterApp();
}

function loadUserState(email){
  const saved = localStorage.getItem('mw_lms_'+email);
  if(saved){
    const s = JSON.parse(saved);
    state.completedLessons = new Set(s.completedLessons||[]);
    state.quizScores = s.quizScores||{};
    state.uploads = s.uploads||{};
  } else {
    state.completedLessons = new Set();
    state.quizScores = {};
    state.uploads = {};
  }
}

function saveUserState(){
  if(!state.user) return;
  localStorage.setItem('mw_lms_'+state.user.email, JSON.stringify({
    completedLessons:[...state.completedLessons],
    quizScores:state.quizScores,
    uploads:state.uploads
  }));
}

function showLoginErr(msg){
  const el=document.getElementById('loginErr');
  el.textContent=msg; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),3000);
}
function showRegErr(msg){
  const el=document.getElementById('regErr');
  el.textContent=msg; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),3000);
}

function doLogout(){
  state.user=null;
  document.getElementById('authScreen').classList.add('active');
  document.getElementById('appScreen').classList.remove('active');
  document.getElementById('authScreen').style.display='flex';
  document.getElementById('appScreen').style.display='none';
}

function enterApp(){
  document.getElementById('authScreen').style.display='none';
  document.getElementById('authScreen').classList.remove('active');
  document.getElementById('appScreen').style.display='flex';
  document.getElementById('appScreen').classList.add('active');
  initApp();
}

// ══════════════════════════════════════════
//  APP INIT
// ══════════════════════════════════════════
function initApp(){
  const u = state.user;
  const firstName = u.name.split(' ')[0];
  const initials = u.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);

  document.getElementById('sbUserName').textContent = u.name;
  document.getElementById('sbAvatarLetter').textContent = initials;
  document.getElementById('greetName').textContent = firstName;
  document.getElementById('profileName').textContent = u.name;
  document.getElementById('profileEmail').textContent = u.email;
  document.getElementById('profileAvatar').textContent = initials;
  document.getElementById('pf-fname').value = u.name.split(' ')[0]||'';
  document.getElementById('pf-lname').value = u.name.split(' ')[1]||'';
  document.getElementById('pf-email').value = u.email;
  document.getElementById('ps-lessons').textContent = state.completedLessons.size;

  updateGlobalProgress();
  renderDashModules();
  renderModulesPage();
  renderMaterials();
  updateStats();
  nav('dashboard');
}

function getTotalLessons(){
  return COURSE.modules.reduce((s,m)=>s+m.lessons.length,0);
}

function getCompletedModules(){
  return COURSE.modules.filter(m=>m.lessons.every(l=>state.completedLessons.has(l.id))).length;
}

function isModuleUnlocked(modIdx){
  if(modIdx===0) return true;
  const prev = COURSE.modules[modIdx-1];
  return prev.lessons.every(l=>state.completedLessons.has(l.id));
}

function getModuleProgress(mod){
  const done = mod.lessons.filter(l=>state.completedLessons.has(l.id)).length;
  return {done, total:mod.lessons.length, pct:Math.round(done/mod.lessons.length*100)};
}

function updateGlobalProgress(){
  const total = getTotalLessons();
  const done = state.completedLessons.size;
  const pct = Math.round(done/total*100);
  document.getElementById('globalProgressFill').style.width=pct+'%';
  document.getElementById('globalProgressText').textContent=done+' из '+total+' уроков';
  document.getElementById('globalProgressPct').textContent=pct+'%';
  document.getElementById('ps-pct').textContent=pct+'%';
  document.getElementById('ps-mods').textContent=getCompletedModules();
  document.getElementById('ps-lessons').textContent=done;
}

function updateStats(){
  const done = state.completedLessons.size;
  const total = getTotalLessons();
  document.getElementById('statLessons').textContent=done;
  document.getElementById('statModules').textContent=getCompletedModules();

  const scores = Object.values(state.quizScores);
  const avg = scores.length ? Math.round(scores.reduce((a,b)=>a+b,0)/scores.length)+'%' : '—';
  document.getElementById('statQuiz').textContent=avg;

  // Achievements
  if(done>0) document.getElementById('ach1').classList.remove('ach-locked');
  const scoreVals = Object.values(state.quizScores);
  if(scoreVals.some(s=>s>=90)) document.getElementById('ach2').classList.remove('ach-locked');
  if(done/total>=0.5) document.getElementById('ach3').classList.remove('ach-locked');
  if(done===total) document.getElementById('ach4').classList.remove('ach-locked');

  // Next lesson
  updateNextLesson();
}

function updateNextLesson(){
  for(let mi=0;mi<COURSE.modules.length;mi++){
    if(!isModuleUnlocked(mi)) continue;
    const mod = COURSE.modules[mi];
    for(let li=0;li<mod.lessons.length;li++){
      const l = mod.lessons[li];
      if(!state.completedLessons.has(l.id)){
        document.getElementById('nextLessonTitle').textContent=l.title;
        document.getElementById('nextLessonMeta').textContent='Модуль '+(mi+1)+' — Урок '+(li+1);
        state._nextLesson={mi,li};
        return;
      }
    }
  }
  // All done
  document.getElementById('nextLessonBanner').innerHTML='<div class="nlb-tag">Курс завершён</div><div class="nlb-title">Поздравляем! ✈️</div><div class="nlb-module">Все модули пройдены</div>';
}

function openNextLesson(){
  if(!state._nextLesson) return;
  openLesson(state._nextLesson.mi, state._nextLesson.li);
}

// ══════════════════════════════════════════
//  RENDER DASHBOARD MODULES
// ══════════════════════════════════════════
function renderDashModules(){
  const el = document.getElementById('dashModuleList');
  el.innerHTML='';
  COURSE.modules.forEach((mod,mi)=>{
    const unlocked = isModuleUnlocked(mi);
    const {done,total,pct} = getModuleProgress(mod);
    const allDone = done===total;
    const div=document.createElement('div');
    div.className='mpl-item'+(unlocked?'':' locked')+(mod.id===1?' active':'');
    div.innerHTML=`
      <div class="mpl-num">${String(mod.id).padStart(2,'0')}</div>
      <div class="mpl-body">
        <div class="mpl-title">${mod.title}</div>
        <div class="mpl-meta">${total} уроков · ${mod.tag}</div>
      </div>
      <div class="mpl-bar-wrap">
        <div class="mpl-mini-bar"><div class="mpl-mini-fill" style="width:${pct}%"></div></div>
        <div class="mpl-pct">${pct}%</div>
      </div>
      <div class="mpl-status">
        <span class="badge ${allDone?'done':unlocked?'active':'locked'}">${allDone?'✓ Готово':unlocked?'Активен':'🔒 Закрыт'}</span>
      </div>`;
    if(unlocked) div.onclick=()=>{nav('modules'); setTimeout(()=>toggleModule(mi),100);};
    el.appendChild(div);
  });
}

// ══════════════════════════════════════════
//  RENDER MODULES PAGE
// ══════════════════════════════════════════
function renderModulesPage(){
  const el = document.getElementById('modulesGrid');
  el.innerHTML='';
  COURSE.modules.forEach((mod,mi)=>{
    const unlocked = isModuleUnlocked(mi);
    const {done,total,pct} = getModuleProgress(mod);
    const card=document.createElement('div');
    card.className='mod-card'+(unlocked?'':' locked');
    card.id='modCard'+mi;

    const lessons = mod.lessons.map((l,li)=>{
      const done2 = state.completedLessons.has(l.id);
      const icon = l.type==='quiz'?'📝':l.type==='video'?'📹':l.type==='homework'?'📎':'📄';
      const lUnlocked = unlocked && (li===0 || state.completedLessons.has(mod.lessons[li-1].id));
      return `<div class="lesson-item${lUnlocked?'':' locked-lesson'}" ${lUnlocked?`onclick="openLesson(${mi},${li})"`:''}">
        <div class="lesson-n">${li+1}</div>
        <div class="lesson-info">
          <div class="lesson-title">${l.title}</div>
          <div class="lesson-type">${icon} ${l.type==='quiz'?'Тест':l.type==='video'?'Видеоурок':l.type==='homework'?'Домашнее задание':'Конспект'}</div>
        </div>
        <div class="lesson-duration">${l.duration}</div>
        <div class="lesson-check${done2?' done':''}">
          ${done2?'<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>':''}
        </div>
      </div>`;
    }).join('');

    card.innerHTML=`
      <div class="mod-card-header" onclick="${unlocked?'toggleModule('+mi+')':''}">
        <div class="mc-num">${String(mod.id).padStart(2,'0')}</div>
        <div class="mc-info">
          <div class="mc-tag">${mod.tag}</div>
          <div class="mc-title">${mod.title}</div>
          <div class="mc-desc">${mod.desc}</div>
          <div class="mc-stats">
            <span class="mc-stat"><strong>${total}</strong> урока</span>
            <span class="mc-stat"><strong>${done}</strong> пройдено</span>
          </div>
        </div>
        <div class="mc-right">
          ${unlocked
            ? `<div style="text-align:center"><div style="font-family:'Cormorant',serif;font-size:32px;font-weight:600;color:var(--gold)">${pct}%</div><div style="font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:var(--muted)">прогресс</div></div>
               <button class="mc-expand-btn">Открыть ${unlocked?'›':''}</button>`
            : `<div class="mc-lock-icon">🔒</div><div style="font-size:10px;color:var(--muted);letter-spacing:0.1em">Закрыт</div>`
          }
        </div>
      </div>
      <div class="mod-lessons" id="modLessons${mi}">${lessons}</div>`;
    el.appendChild(card);
  });
}

function toggleModule(mi){
  const card = document.getElementById('modCard'+mi);
  if(!card||card.classList.contains('locked')) return;
  const isOpen = card.classList.contains('open');
  document.querySelectorAll('.mod-card').forEach(c=>c.classList.remove('open'));
  if(!isOpen) card.classList.add('open');
}

// ══════════════════════════════════════════
//  LESSON
// ══════════════════════════════════════════
function openLesson(mi, li){
  const mod = COURSE.modules[mi];
  const lesson = mod.lessons[li];
  state.currentLesson = {mi, li, mod, lesson};
  state.currentQuiz = {q:0, answers:[], answered:false};

  nav('lesson');
  document.getElementById('topbarTitle').textContent = lesson.title;

  // Breadcrumb
  document.getElementById('lv-mod-name').textContent='Модуль '+(mi+1);
  document.getElementById('lv-lesson-name').textContent=lesson.title;

  // Header
  document.getElementById('lv-tag').textContent='Модуль '+(mi+1)+' · '+mod.title;
  document.getElementById('lv-title').textContent=lesson.title;
  const typeLabel = lesson.type==='quiz'?'📝 Тест':lesson.type==='video'?'📹 Видеоурок':lesson.type==='homework'?'📎 Домашнее задание':'📄 Конспект';
  document.getElementById('lv-type').textContent=typeLabel;
  document.getElementById('lv-duration').textContent=lesson.duration;

  // Video, quiz, content
  document.getElementById('lv-video').style.display = lesson.type==='video'?'block':'none';
  const qEl = document.getElementById('lv-quiz-container');
  const cEl = document.getElementById('lv-content');

  if(lesson.type==='quiz'){
    qEl.style.display='block';
    cEl.innerHTML='';
    renderQuiz(lesson.content);
  } else {
    qEl.style.display='none';
    cEl.innerHTML = CONTENT[lesson.content]||'<p>Материал урока в разработке.</p>';
  }

  // Upload
  const upEl = document.getElementById('lv-upload-section');
  upEl.style.display = lesson.hasUpload?'block':'none';
  if(lesson.hasUpload) renderUploads(lesson.id);

  // Materials
  const matEl = document.getElementById('lv-materials');
  const matList = document.getElementById('mat-list');
  if(lesson.materials&&lesson.materials.length){
    matEl.style.display='block';
    matList.innerHTML=lesson.materials.map(m=>`
      <div class="material-item">
        <div class="mat-icon">📄</div>
        <div class="mat-info"><div class="mat-name">${m}</div><div class="mat-size">PDF</div></div>
        <div class="mat-dl">Скачать</div>
      </div>`).join('');
  } else {
    matEl.style.display='none';
  }

  // Sidebar lesson list
  const nlEl = document.getElementById('lessonNavList');
  nlEl.innerHTML = mod.lessons.map((l,idx)=>{
    const isDone = state.completedLessons.has(l.id);
    const isCur = idx===li;
    return `<div class="lnl-item${isCur?' current':''}" onclick="openLesson(${mi},${idx})">
      <div class="lnl-check${isDone?' done':isCur?' current':''}">
        ${isDone?'<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>':''}
      </div>
      <div class="lnl-text">${l.title}</div>
    </div>`;
  }).join('');

  // Nav buttons
  document.getElementById('btnPrev').style.display = li>0?'flex':'none';
  document.getElementById('btnNext').style.display = li<mod.lessons.length-1?'flex':'none';
  const isDone = state.completedLessons.has(lesson.id);
  document.getElementById('btnComplete').style.display = (!isDone&&lesson.type!=='quiz')?'flex':'none';
}

function lessonNav(dir){
  const {mi,li,mod} = state.currentLesson;
  const newLi = li+dir;
  if(newLi>=0 && newLi<mod.lessons.length){
    openLesson(mi,newLi);
  }
}

function completeLesson(){
  const {lesson,mi,li} = state.currentLesson;
  state.completedLessons.add(lesson.id);
  saveUserState();
  updateGlobalProgress();
  updateStats();
  renderDashModules();
  renderModulesPage();
  document.getElementById('btnComplete').style.display='none';
  showToast('Урок отмечен как пройденный ✓');

  // Re-render sidebar
  openLesson(mi,li);
}

// ══════════════════════════════════════════
//  QUIZ
// ══════════════════════════════════════════
function renderQuiz(quizKey){
  const quiz = QUIZZES[quizKey];
  if(!quiz) return;
  state.currentQuiz = {key:quizKey, q:0, answers:[], answered:false, quiz};

  document.getElementById('quiz-title').textContent=quiz.title;
  document.getElementById('qTotal').textContent=quiz.questions.length;
  document.getElementById('quiz-result').style.display='none';
  document.getElementById('quiz-body').style.display='block';
  document.getElementById('quiz-nav').style.display='flex';
  renderQuizQuestion();
}

function renderQuizQuestion(){
  const {quiz,q} = state.currentQuiz;
  const qd = quiz.questions[q];
  document.getElementById('qNum').textContent=q+1;
  document.getElementById('quiz-prog-fill').style.width=((q+1)/quiz.questions.length*100)+'%';
  document.getElementById('quiz-question').textContent=qd.q;
  document.getElementById('quiz-feedback').className='quiz-feedback';
  document.getElementById('quiz-feedback').textContent='';
  document.getElementById('quiz-next-btn').style.display='none';
  document.getElementById('quiz-submit-btn').style.display='none';
  document.getElementById('quiz-hint').textContent='Выберите ответ';
  state.currentQuiz.answered=false;

  const optsEl = document.getElementById('quiz-options');
  optsEl.innerHTML=qd.opts.map((opt,i)=>`
    <div class="quiz-opt" onclick="selectAnswer(${i})">
      <div class="qo-radio"></div>
      <div class="qo-text">${opt}</div>
    </div>`).join('');
}

function selectAnswer(i){
  if(state.currentQuiz.answered) return;
  const {quiz,q} = state.currentQuiz;
  const qd = quiz.questions[q];
  state.currentQuiz.answered=true;
  state.currentQuiz.answers[q]=i;

  const opts = document.querySelectorAll('.quiz-opt');
  opts[i].classList.add('selected');

  const isCorrect = i===qd.correct;
  opts[i].classList.add(isCorrect?'correct':'wrong');
  if(!isCorrect) opts[qd.correct].classList.add('correct');

  const fb = document.getElementById('quiz-feedback');
  fb.textContent = isCorrect ? '✓ Верно! '+qd.exp : '✗ Неверно. '+qd.exp;
  fb.className = 'quiz-feedback show '+(isCorrect?'correct':'wrong');

  const isLast = q===quiz.questions.length-1;
  document.getElementById('quiz-hint').textContent='';
  if(isLast){
    document.getElementById('quiz-submit-btn').style.display='flex';
  } else {
    document.getElementById('quiz-next-btn').style.display='flex';
  }
}

function quizNext(){
  state.currentQuiz.q++;
  renderQuizQuestion();
}

function quizSubmit(){
  const {quiz,answers,key} = state.currentQuiz;
  const correct = answers.filter((a,i)=>a===quiz.questions[i].correct).length;
  const total = quiz.questions.length;
  const pct = Math.round(correct/total*100);

  state.quizScores[key]=pct;
  state.completedLessons.add(state.currentLesson.lesson.id);
  saveUserState();
  updateGlobalProgress();
  updateStats();
  renderModulesPage();
  renderDashModules();

  const pass = pct>=70;
  document.getElementById('quiz-body').style.display='none';
  document.getElementById('quiz-nav').style.display='none';
  const res = document.getElementById('quiz-result');
  res.style.display='block';
  res.innerHTML=`
    <div class="qr-score-wrap">
      <div class="qr-score">${pct}%</div>
      <div class="qr-score-label">${correct} из ${total} правильных ответов</div>
    </div>
    <div class="qr-title ${pass?'qr-pass':'qr-fail'}">${pass?'<em>Отлично!</em>':'Попробуйте ещё раз'}</div>
    <div class="qr-text">${pass?'Тест пройден успешно. Следующий урок теперь доступен.':'Минимальный проходной балл — 70%. Вернитесь к материалам и попробуйте снова.'}</div>
    <div style="display:flex;gap:12px;justify-content:center;margin-top:24px;">
      ${pass?`<button class="btn-next" onclick="lessonNav(1)">Следующий урок →</button>`:''}
      <button class="btn-prev" onclick="renderQuiz('${key}')">Пройти снова</button>
    </div>`;

  showToast(pass?'Тест пройден — '+pct+'%!':'Результат: '+pct+'%. Попробуйте ещё раз');
}

// ══════════════════════════════════════════
//  UPLOADS
// ══════════════════════════════════════════
function dragOver(e){e.preventDefault();document.getElementById('uploadZone').classList.add('drag');}
function dragLeave(){document.getElementById('uploadZone').classList.remove('drag');}
function dropFile(e){
  e.preventDefault();
  document.getElementById('uploadZone').classList.remove('drag');
  if(e.dataTransfer.files[0]) processUpload(e.dataTransfer.files[0]);
}
function handleUpload(inp){if(inp.files[0]) processUpload(inp.files[0]);}
function processUpload(file){
  const {lesson} = state.currentLesson;
  if(!state.uploads[lesson.id]) state.uploads[lesson.id]=[];
  const entry={name:file.name,size:Math.round(file.size/1024)+'KB',date:new Date().toLocaleDateString('ru-RU')};
  state.uploads[lesson.id].push(entry);
  saveUserState();
  renderUploads(lesson.id);
  showToast('Файл загружен: '+file.name);
}
function renderUploads(lid){
  const list = document.getElementById('uploadedList');
  const files = state.uploads[lid]||[];
  list.innerHTML=files.map((f,i)=>`
    <div class="ul-item">
      <div class="ul-icon">📎</div>
      <div class="ul-name">${f.name}</div>
      <div class="ul-size">${f.size}</div>
      <button class="ul-del" onclick="removeUpload('${lid}',${i})">×</button>
    </div>`).join('');
}
function removeUpload(lid,i){
  state.uploads[lid].splice(i,1);
  saveUserState();
  renderUploads(lid);
}

// ══════════════════════════════════════════
//  MATERIALS PAGE
// ══════════════════════════════════════════
function renderMaterials(){
  const el = document.getElementById('allMaterials');
  el.innerHTML='';
  COURSE.modules.forEach((mod,mi)=>{
    const unlocked = isModuleUnlocked(mi);
    mod.lessons.forEach(l=>{
      if(!l.materials||!l.materials.length) return;
      l.materials.forEach(m=>{
        const div=document.createElement('div');
        div.className='mpl-item'+(unlocked?'':' locked');
        div.innerHTML=`
          <div class="mpl-num" style="font-size:20px;padding:14px 20px;">📄</div>
          <div class="mpl-body">
            <div class="mpl-title">${m}</div>
            <div class="mpl-meta">Модуль ${mod.id} · ${l.title}</div>
          </div>
          <div class="mpl-status">
            <span class="badge ${unlocked?'active':'locked'}">${unlocked?'Скачать':'🔒'}</span>
          </div>`;
        el.appendChild(div);
      });
    });
  });
}

// ══════════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════════
function nav(page){
  document.querySelectorAll('.page-view').forEach(el=>el.classList.remove('on'));
  document.querySelectorAll('.sb-nav-item').forEach(el=>el.classList.remove('on'));
  const pageEl = document.getElementById('pv-'+page);
  if(pageEl) pageEl.classList.add('on');
  const titles = {dashboard:'Главная',modules:'Модули курса',lesson:'Урок',schedule:'Расписание',materials:'Материалы',profile:'Мой профиль'};
  document.getElementById('topbarTitle').textContent = titles[page]||'';

  const navMap = {dashboard:0,modules:1,schedule:2,materials:3,profile:4};
  const items = document.querySelectorAll('.sb-nav-item');
  if(navMap[page]!==undefined && items[navMap[page]]) items[navMap[page]].classList.add('on');

  // Close sidebar on mobile
  if(window.innerWidth<=768){
    document.getElementById('sidebar').classList.remove('open');
  }

  // Re-render materials and modules when navigating there
  if(page==='materials') renderMaterials();
  if(page==='modules') renderModulesPage();
}

// ══════════════════════════════════════════
//  NOTIFICATIONS
// ══════════════════════════════════════════
function toggleNotif(){
  const panel = document.getElementById('notifPanel');
  const overlay = document.getElementById('notifOverlay');
  const open = panel.classList.toggle('open');
  overlay.classList.toggle('on',open);
  if(open){
    document.getElementById('notifBadge').style.display='none';
  }
}

// ══════════════════════════════════════════
//  PROFILE
// ══════════════════════════════════════════
function saveProfile(){
  const fn = document.getElementById('pf-fname').value.trim();
  const ln = document.getElementById('pf-lname').value.trim();
  const em = document.getElementById('pf-email').value.trim();
  const name = (fn+' '+ln).trim();
  state.user.name=name;
  state.user.email=em;
  document.getElementById('sbUserName').textContent=name;
  const initials=name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('sbAvatarLetter').textContent=initials;
  document.getElementById('profileAvatar').textContent=initials;
  document.getElementById('profileName').textContent=name;
  document.getElementById('profileEmail').textContent=em;
  document.getElementById('greetName').textContent=fn||name;
  const users=JSON.parse(localStorage.getItem('mw_users')||'[]');
  const idx=users.findIndex(u=>u.email===state.user.email);
  if(idx>-1){users[idx]={...users[idx],name,email:em};localStorage.setItem('mw_users',JSON.stringify(users));}
  showToast('Профиль обновлён');
}

// ══════════════════════════════════════════
//  MOBILE SIDEBAR
// ══════════════════════════════════════════
function toggleSidebar(){
  document.getElementById('sidebar').classList.toggle('open');
}

// ══════════════════════════════════════════
//  TOAST
// ══════════════════════════════════════════
function showToast(msg){
  const t=document.getElementById('toast');
  document.getElementById('toastMsg').textContent=msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}

// ══════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════
window.addEventListener('DOMContentLoaded',()=>{
  loadState();
  // Demo login shortcut visible in dev
  // Add demo user if none exist
  const users=JSON.parse(localStorage.getItem('mw_users')||'[]');
  if(!users.find(u=>u.email==='demo@mwskyway.com')){
    users.push({name:'Алина Маратова',email:'demo@mwskyway.com',pass:'skyway123',joined:'Июнь 2025'});
    localStorage.setItem('mw_users',JSON.stringify(users));
  }
  if(state.user){
    enterApp();
  } else {
    document.getElementById('authScreen').style.display='flex';
  }
});
</script>
</body>
</html>
